                <ml id='ID2536809782'>
                    fun max_sum_time [(t1, d1), (t2, d2)] =
  if t1 + d1 &gt;= t2 + d2 then t1 + d1 else t2 + d2;
                </ml>
                <ml id='ID2597693049'>
                    fun maxTime(a:int,b:int,c:int,d:int)= if a+b &gt;= c+d then a+b else c+d;
